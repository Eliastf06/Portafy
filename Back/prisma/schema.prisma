// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  nom_usuario   String    @id @unique
  nombre        String
  email         String    @unique
  contrasena    String
  tipo_usuario  TipoUsuario
  foto_perfil   String?
  biografia     String?   @db.Text
  red_social    String?
  proyectos     Proyecto[]
  experiencias  Exp_Lbl[]

  @@map("usuarios")
}

model Exp_Lbl {
  id_exp        Int       @id @default(autoincrement())
  empresa       String
  cargo         String
  fecha_inicio  DateTime
  fecha_salida  DateTime
  usuario       Usuario   @relation(fields: [nom_usuario], references: [nom_usuario])
  nom_usuario   String

  @@map("experiencias_laborales")
}

model Proyecto {
  id_proyecto   Int       @id @default(autoincrement())
  titulo        String
  descripcion   String    @db.Text
  categoria     String
  fecha_publi   DateTime  @default(now())
  usuario       Usuario   @relation(fields: [nom_usuario], references: [nom_usuario])
  nom_usuario   String
  archivos      Archivo[]

  @@map("proyectos")
}

model Archivo {
  id_archivo    Int       @id @default(autoincrement())
  tipo_archivo  String
  url           String
  proyecto      Proyecto  @relation(fields: [id_proyecto], references: [id_proyecto])
  id_proyecto   Int

  @@map("archivos")
}

enum TipoUsuario {
  programador
  visual
}