// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  nom_usuario  String      @id @unique
  nombre       String
  email        String      @unique
  contrasena   String
  tipo_usuario String // <-- Este campo ahora es un String
  proyectos    Proyecto[]
  datosPerfil  DatosPerfil?

  @@map("usuarios")
}

model DatosPerfil {
  id_datos_perfil Int       @id @default(autoincrement())
  privacidad      Boolean   @default(false)
  biografia       String?   @db.Text
  red_social      String?
  foto_perfil     String?
  telefono        String?
  direccion       String?
  experiencia     String?   @db.Text
  usuario         Usuario   @relation(fields: [nom_usuario], references: [nom_usuario])
  nom_usuario     String    @unique

  @@map("datos_perfil")
}

model Proyecto {
  id_proyecto         Int        @id @default(autoincrement())
  titulo              String
  descripcion         String     @db.Text
  categoria           String
  fecha_publi         DateTime   @default(now())
  fecha_inicio        DateTime?  @db.Date
  fecha_finalizacion  DateTime?  @db.Date
  para_quien_se_hizo  String?
  enlaces_referencia  String?
  privacidad          Boolean?   @default(false)
  usuario             Usuario    @relation(fields: [nom_usuario], references: [nom_usuario])
  nom_usuario         String
  archivos            Archivo[]

  @@map("proyectos")
}

model Archivo {
  id_archivo   Int      @id @default(autoincrement())
  tipo_archivo String
  url          String
  nombre       String   @default("")
  proyecto     Proyecto @relation(fields: [id_proyecto], references: [id_proyecto])
  id_proyecto  Int

  @@map("archivos")
}